[Unit]
Description=tmux session for user %I
After=graphical-session.target

[Service]
Type=forking
ExecStartPre=systemctl --user import-environment DISPLAY WAYLAND_DISPLAY XDG_SESSION_TYPE XDG_SESSION_DESKTOP GPG_TTY XDG_CURRENT_DESKTOP
ExecStart=%h/.nix-profile/bin/tmux new-session -s %I -d
ExecStop=%h/.nix-profile/bin/tmux kill-session -t %I
Restart=always

[Install]
# Wants=xwayland-satellite.service
WantedBy=default.target
